#!/usr/bin/env bash
# PromptPal launcher (US-012).
#
# Responsibilities:
#   1. Duplicate the WSL HOME guard from core/platform.py
#      (P1-PLAT-03 / P1-ERR-12) so the fix message reaches the user
#      BEFORE Python imports anything that might choke on an NTFS HOME.
#   2. Exec ``python3 <repo_root>/promptpal_main.py`` so Python becomes
#      the process and inherits signals cleanly (no orphaned wrapper).
#
# Why invoke the bootstrap by path instead of ``python3 -m core.main``?
# ``-m`` puts the *current working directory* on ``sys.path[0]``, so
# running promptpal from a directory that has its own ``core/`` package
# (the source checkout, or any project with a ``core`` module) would
# shadow the real package. Running a script by path puts the *script's*
# directory on ``sys.path[0]`` instead — never the CWD. See
# promptpal_main.py for the full rationale.
#
# Keep the WSL message text in sync with WSL_LAUNCH_FIX_MESSAGE in
# core/platform.py. Tests pin the bash output against that constant so
# the two cannot drift silently.

set -euo pipefail

case "${HOME:-}" in
    /mnt/c/*|/c/*)
        printf '%s\n' \
            'Warning: HOME appears to be a Windows path.' \
            'For best results, launch from WSL:' \
            '  wsl -d Ubuntu -- promptpal' >&2
        exit 1
        ;;
esac

# Resolve the repo root relative to this script so the bootstrap path is
# absolute regardless of the caller's cwd.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

exec python3 "${repo_root}/promptpal_main.py" "$@"
